# Brevo API Key for sending consent emails
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxx

# Sender email (must be verified in Brevo account)
# Go to: https://app.brevo.com/senders/list to add/verify senders
SENDER_EMAIL=noreply@yourdomain.com

# Optional: Override sender display name
# SENDER_NAME=PianoMaster

# Lemon Squeezy API key for server-side calls (create checkout, cancel subscription)
# Get from: https://app.lemonsqueezy.com/settings/api
LS_API_KEY=your_ls_api_key_here

# Lemon Squeezy Store ID
# Get from: https://app.lemonsqueezy.com/settings/stores
LS_STORE_ID=your_ls_store_id_here

# Lemon Squeezy Webhook Signing Secret (already used by lemon-squeezy-webhook function)
# LS_SIGNING_SECRET=your_signing_secret_here
